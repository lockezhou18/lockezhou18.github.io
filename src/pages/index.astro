---
import { getCollection } from "astro:content";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Notes on building AI infrastructure and systems." />
    <title>lockezhou18</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --color-bg: #ffffff;
        --color-text: #1f2328;
        --color-muted: #636e7b;
        --color-border: #d0d7de;
        --color-link: #0969da;
        --color-header-bg: #f6f8fa;
        --font: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica, Arial, sans-serif;
      }

      html { background: var(--color-bg); color: var(--color-text); }
      body { font-family: var(--font); font-size: 1rem; line-height: 1.6; }

      .site-header {
        border-bottom: 1px solid var(--color-border);
        padding: 0.75rem 1.5rem;
      }
      .site-header nav {
        max-width: 800px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .logo {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--color-text);
        text-decoration: none;
      }
      .github-link {
        font-size: 0.875rem;
        color: var(--color-text);
        text-decoration: none;
        opacity: 0.6;
      }
      .github-link:hover { opacity: 1; }

      .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1.5rem 5rem;
      }

      .intro {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border);
      }
      .intro p {
        color: var(--color-muted);
        font-size: 0.9375rem;
      }

      .post-list {
        list-style: none;
        padding: 0;
      }
      .post-item {
        padding: 1.25rem 0;
        border-bottom: 1px solid var(--color-border);
      }
      .post-date {
        font-size: 0.8125rem;
        color: var(--color-muted);
        margin-bottom: 0.25rem;
      }
      .post-title {
        font-size: 1.125rem;
        font-weight: 600;
        line-height: 1.3;
        margin-bottom: 0.25rem;
      }
      .post-title a {
        color: var(--color-link);
        text-decoration: none;
      }
      .post-title a:hover { text-decoration: underline; }
      .post-description {
        font-size: 0.9375rem;
        color: var(--color-muted);
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <span class="logo">lockezhou18</span>
        <a href="https://github.com/lockezhou18" class="github-link">github.com/lockezhou18 →</a>
      </nav>
    </header>
    <main class="container">
      <div class="intro">
        <p>Notes on building AI infrastructure, agents, and the systems underneath.</p>
      </div>
      <ul class="post-list">
        {posts.map((post) => {
          const formatted = post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          });
          return (
            <li class="post-item">
              <p class="post-date">{formatted}</p>
              <h2 class="post-title">
                <a href={`/${post.slug}`}>{post.data.title}</a>
              </h2>
              <p class="post-description">{post.data.description}</p>
            </li>
          );
        })}
      </ul>
    </main>
  </body>
</html>
