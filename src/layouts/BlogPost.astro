---
interface Props {
  title: string;
  date: Date;
  description: string;
}
const { title, date, description } = Astro.props;
const formatted = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --color-bg: #ffffff;
        --color-text: #1f2328;
        --color-muted: #636e7b;
        --color-border: #d0d7de;
        --color-link: #0969da;
        --color-code-bg: #f6f8fa;
        --color-code-border: #d0d7de;
        --color-pre-bg: #161b22;
        --color-pre-text: #e6edf3;
        --font: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica, Arial, sans-serif;
        --font-mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
      }

      html { background: var(--color-bg); color: var(--color-text); }
      body { font-family: var(--font); font-size: 1rem; line-height: 1.6; }

      .site-header {
        border-bottom: 1px solid var(--color-border);
        padding: 0.75rem 1.5rem;
      }
      .site-header nav {
        max-width: 800px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .site-header a {
        font-size: 0.875rem;
        color: var(--color-text);
        text-decoration: none;
        opacity: 0.6;
      }
      .site-header a:hover { opacity: 1; }

      .post-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1.5rem 5rem;
      }

      .post-meta {
        font-size: 0.8125rem;
        color: var(--color-muted);
        margin-bottom: 0.5rem;
      }

      .post-title {
        font-size: 2rem;
        font-weight: 600;
        line-height: 1.25;
        color: var(--color-text);
        margin-bottom: 0.5rem;
        border-bottom: 1px solid var(--color-border);
        padding-bottom: 0.5rem;
      }

      .post-description {
        font-size: 1rem;
        color: var(--color-muted);
        margin-bottom: 2rem;
      }

      /* Prose — GitHub markdown style */
      .prose h2 {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 2rem 0 0.75rem;
        padding-bottom: 0.3rem;
        border-bottom: 1px solid var(--color-border);
      }
      .prose h3 { font-size: 1.25rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
      .prose p { margin-bottom: 1rem; }
      .prose a { color: var(--color-link); text-decoration: none; }
      .prose a:hover { text-decoration: underline; }
      .prose ul, .prose ol { margin: 0 0 1rem 2rem; }
      .prose li { margin-bottom: 0.25rem; }
      .prose blockquote {
        border-left: 4px solid var(--color-border);
        padding: 0 1rem;
        color: var(--color-muted);
        margin: 1rem 0;
      }
      .prose code {
        background: var(--color-code-bg);
        border: 1px solid var(--color-code-border);
        border-radius: 6px;
        padding: 0.2em 0.4em;
        font-size: 0.85em;
        font-family: var(--font-mono);
      }
      .prose pre {
        background: var(--color-pre-bg) !important;
        color: var(--color-pre-text);
        border-radius: 6px;
        padding: 1rem;
        overflow-x: auto;
        margin: 1rem 0;
        font-size: 0.875rem;
        line-height: 1.5;
        border: 1px solid #30363d;
      }
      .prose pre code {
        background: none;
        border: none;
        padding: 0;
        font-size: inherit;
        color: inherit;
      }
      .prose hr { border: none; border-top: 1px solid var(--color-border); margin: 2rem 0; }
      .prose img { max-width: 100%; border-radius: 6px; margin: 1rem 0; border: 1px solid var(--color-border); }
      .prose table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.9375rem; display: block; overflow-x: auto; }
      .prose th, .prose td { text-align: left; padding: 0.375rem 0.8125rem; border: 1px solid var(--color-border); }
      .prose thead { background: var(--color-code-bg); }
      .prose th { font-weight: 600; }
      .prose tr:nth-child(even) td { background: #f6f8fa; }

      .comments {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        border-top: 1px solid var(--color-border);
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/">← lockezhou18</a>
        <a href="https://github.com/lockezhou18">github.com/lockezhou18 →</a>
      </nav>
    </header>
    <article class="post-container">
      <p class="post-meta">{formatted}</p>
      <h1 class="post-title">{title}</h1>
      <p class="post-description">{description}</p>
      <div class="prose">
        <slot />
      </div>
    </article>
    <div class="comments">
      <script src="https://giscus.app/client.js"
        data-repo="lockezhou18/lockezhou18.github.io"
        data-repo-id="R_kgDOSJ2Cig"
        data-category="General"
        data-category-id="DIC_kwDOSJ2Cis4C7crr"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="light"
        data-lang="en"
        crossorigin="anonymous"
        async>
      </script>
    </div>
  </body>
</html>
